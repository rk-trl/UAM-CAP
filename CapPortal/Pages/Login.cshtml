@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="login-container">
    <div class="login-card">
        <div class="logo-section">
            <div class="logo-icon">
                <i class="bi bi-building"></i>
            </div>
            <div class="logo-text">
                <div class="logo-main">Talent Solutions</div>
                <div class="logo-sub">ManpowerGroup</div>
            </div>
        </div>
        <h2>CAP Portal</h2>
        <p>Candidate Assessment Platform</p>
        <a href="/MicrosoftIdentity/Account/SignIn" class="btn btn-primary btn-lg">Sign In</a>
    </div>
</div>