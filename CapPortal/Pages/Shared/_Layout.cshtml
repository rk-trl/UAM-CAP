<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CapPortal</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex" style="height: 100vh;">
        <!-- Sidebar -->
        <div class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="logo-section">
                    <div class="logo-icon">
                        <i class="bi bi-building"></i>
                    </div>
                    <div class="logo-text">
                        <div class="logo-main">Talent Solutions</div>
                        <div class="logo-sub">ManpowerGroup</div>
                    </div>
                </div>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section">
                    <a href="/" class="nav-item">
                        <i class="bi bi-house-door"></i>
                        <span>Home</span>
                    </a>
                </div>
            </nav>

            <div class="sidebar-footer">
                <a href="#" class="dropdown-item">
                    <i class="bi bi-gear"></i> Account and Settings
                </a>
                <a href="#" class="dropdown-item">
                    <i class="bi bi-question-circle"></i> Help and Support
                </a>
                <a href="/MicrosoftIdentity/Account/SignOut" class="dropdown-item">
                    <i class="bi bi-box-arrow-right"></i> Sign Out
                </a>
            </div>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Top Header -->
            <header class="top-header">
                <button class="sidebar-toggle" id="sidebarToggle">
                    <i class="bi bi-list"></i>
                </button>
                <div class="header-title">
                    @ViewData["Title"] ?? "Home"
                </div>
                <div class="header-actions">
                    <span class="user-greeting">Welcome, @User.Identity?.Name</span>
                </div>
            </header>

            <!-- Page Content -->
            <main role="main" class="page-content">
                @RenderBody()
            </main>

            <!-- Footer -->
            <footer class="footer">
                <div class="container">
                    Talent Solutions platform powered by ManpowerGroup
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Sidebar toggle
        document.getElementById('sidebarToggle').addEventListener('click', function () {
            document.getElementById('sidebar').classList.toggle('collapsed');
            document.querySelector('.main-content').classList.toggle('expanded');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
