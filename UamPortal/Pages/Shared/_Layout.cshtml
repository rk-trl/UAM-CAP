<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UamPortal</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex" style="height: 100vh;">
        <!-- Sidebar -->
        <div class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="logo-section">
                    <div class="logo-icon">
                        <i class="bi bi-building"></i>
                    </div>
                    <div class="logo-text">
                        <div class="logo-main">Talent Solutions</div>
                        <div class="logo-sub">ManpowerGroup</div>
                    </div>
                </div>
            </div>

            <div class="user-profile-section">
                <div class="user-profile">
                    <div class="user-avatar">
                        @{
                            var initials = (User.Identity?.Name ?? "U").Split('@')[0].ToUpper();
                            if (initials.Length > 2) initials = initials.Substring(0, 2);
                        }
                        @initials
                    </div>
                    <div class="user-info">
                        <div class="user-name">Super Admin</div>
                    </div>
                    <div class="user-dropdown">
                        <i class="bi bi-chevron-down"></i>
                    </div>
                </div>
                <div class="dropdown-menu-profile">
                    <a href="#" class="dropdown-item">
                        <i class="bi bi-person"></i> Profile
                    </a>
                    <a href="/logout" class="dropdown-item">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section">
                    <a href="/" class="nav-item">
                        <i class="bi bi-house-door"></i>
                        <span>Dashboard</span>
                    </a>
                </div>

                <div class="nav-section">
                    <a href="/usermanagement" class="nav-item">
                        <i class="bi bi-people"></i>
                        <span>Manage Users</span>
                    </a>
                </div>
            </nav>

            <div class="sidebar-footer">
                <a href="#" class="dropdown-item">
                    <i class="bi bi-gear"></i> Account and Settings
                </a>
                <a href="#" class="dropdown-item">
                    <i class="bi bi-question-circle"></i> Help and Support
                </a>
                <a href="/MicrosoftIdentity/Account/SignOut" class="dropdown-item">
                    <i class="bi bi-box-arrow-right"></i> Sign Out
                </a>
                <button class="theme-toggle" id="themeToggle">
                    <i class="bi bi-moon"></i>
                    <span>Dark Mode</span>
                </button>
            </div>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Top Header -->
            <header class="top-header">
                <button class="sidebar-toggle" id="sidebarToggle">
                    <i class="bi bi-list"></i>
                </button>
                <div class="header-title">
                    @ViewData["Title"] ?? "Dashboard"
                </div>
                <div class="header-actions">
                    <span class="user-greeting">Welcome, Super Admin</span>
                </div>
            </header>

            <!-- Page Content -->
            <main role="main" class="page-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Sidebar toggle
        document.getElementById('sidebarToggle').addEventListener('click', function () {
            document.getElementById('sidebar').classList.toggle('collapsed');
            document.querySelector('.main-content').classList.toggle('expanded');
        });

        // Theme toggle
        document.getElementById('themeToggle').addEventListener('click', function () {
            document.body.classList.toggle('dark-mode');
            localStorage.setItem('darkMode', document.body.classList.contains('dark-mode'));
        });

        // Collapse toggle for group items
        document.querySelectorAll('[data-toggle="collapse"]').forEach(btn => {
            btn.addEventListener('click', function () {
                const target = document.querySelector(this.getAttribute('data-target'));
                target.classList.toggle('show');
            });
        });

        // Load theme preference
        if (localStorage.getItem('darkMode') === 'true') {
            document.body.classList.add('dark-mode');
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
